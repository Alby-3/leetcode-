class Solution:
    def wateringPlants(self, plants: List[int], capacity: int) -> int:
        steps=0
        can =capacity
        for i in range(len(plants)):
            if (plants[i]<=can):
                can=can-plants[i]
                steps=steps+1
            else:
                can=capacity-plants[i]
                steps=steps+((i*2)+1)
        return steps
