class Solution:
    def reverse(self, x: int) -> int:
        if x > -2**31 and x < 2**31 - 1:
            y = x
            if y < 0:
                y = x * -1

            reverse = 0

            while y > 0:
                digit = y % 10
                reverse = reverse * 10 + digit
                y = y // 10

            if x < 0:
                reverse = -reverse
            if reverse> -2**31 and reverse< 2**31 - 1:
              return reverse
            else:
                return 0
        else:
            return 0
