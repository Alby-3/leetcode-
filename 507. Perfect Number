class Solution:
    def checkPerfectNumber(self, num: int) -> bool:
        val = 0
        if num == 1 or num>99999991:
            return False
        else:
            for i in range(1, num // 2 + 1):
                if num % i == 0:
                    val = val + i
            if val == num:
                return True
            else:
                return False
