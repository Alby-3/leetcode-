class Solution:
    def addStrings(self, num1: str, num2: str) -> str:
        carry = 0
        m = []

        n1 = num1[::-1]
        n2 = num2[::-1]

        l1 = len(n1)
        l2 = len(n2)

        
        if l1 > l2:
            n2 += "0" * (l1 - l2)
        else:
            n1 += "0" * (l2 - l1)

       
        for i in range(len(n1)):
            total = int(n1[i]) + int(n2[i]) + carry
            res = total % 10
            carry = total // 10
            m.append(str(res))

        if carry > 0:
            m.append(str(carry))

        return "".join(m[::-1])
