class Solution:
    def merge(self, nums1: List[int], m: int, nums2: List[int], n: int) -> None:
        """
        Do not return anything, modify nums1 in-place instead.
        """
        total=m+n
        j=n-1
        l=total-1
        k=m-1
        while(k>-1 and j>-1):
            if nums2[j]>nums1[k]:
                nums1[l]=nums2[j]
                l-=1
                j-=1                        
            else:
                nums1[l]=nums1[k]
                k-=1
                l-=1
        while(j>=0):
            nums1[l]=nums2[j]
            j-=1
            l-=1
        return 
